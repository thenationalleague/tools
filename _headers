# NL Tools — GitHub Pages cache headers
# These tell browsers to always revalidate system files rather than serving stale cached versions.
# This means deploying nl-topbar.js, nl-brand.css etc. takes effect immediately for all users
# without needing to bump ?v= query params in every tool page.
#
# Place this file at the repo ROOT (same level as the tools/ folder).
# GitHub Pages reads it automatically.

/tools/system/*
  Cache-Control: no-cache, must-revalidate

/tools/assets/icons/*
  Cache-Control: public, max-age=604800

/tools/assets/crests/*
  Cache-Control: public, max-age=604800

/tools/manifest.json
  Cache-Control: no-cache, must-revalidate

/tools/sw.js
  Cache-Control: no-cache, must-revalidate
